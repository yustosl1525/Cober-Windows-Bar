{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Cober Windows Bar",
  "version": "0.1.0",
  "identifier": "com.cober.windowsbar",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173/desktop",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Cober Windows Bar",
        "width": 960,
        "height": 640,
        "minWidth": 720,
        "minHeight": 520,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
